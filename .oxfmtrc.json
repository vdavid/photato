{
  "$schema": "./frontend/node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "printWidth": 120,
  "proseWrap": "always",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    "**/dist/",
    "**/build/",
    "**/playwright-report/",
    "**/test-results/",
    "**/coverage/",
    "pnpm-lock.yaml",
    "**/*.md"
  ]
}
