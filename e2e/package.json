{
  "name": "e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright E2E + pixel-screenshot baseline for photato.eu. Outlives the frontend implementation swaps (Vite → TypeScript → Svelte).",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "test:e2e:docker": "bash scripts/docker-test.sh",
    "test:e2e:docker:update": "bash scripts/docker-test.sh --update-snapshots",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "oxfmt": "^0.46.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
