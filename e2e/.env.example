# Copy to .env and fill in the real secret (see the box env file /etc/photato-deploy.env).
# .env is gitignored; never commit real credentials.

# Enables the magic-link e2e backdoor (POST /auth/test-login), used by the authenticated specs to mint
# a session without the email round-trip. Get it from the box:
#   ssh hetzner "docker run --rm -v /etc/photato-deploy.env:/f:ro alpine grep TEST_LOGIN_SECRET /f"
# When unset, the authenticated specs skip.
TEST_LOGIN_SECRET=

# Optional overrides:
# Target to run against. Default: https://photato.eu (the live site).
# BASE_URL=https://photato.eu

# Backend base URL for the test-login backdoor. Default: https://api.photato.eu.
# API_BASE_URL=https://api.photato.eu
