# Copy to .env and fill in the real password (see the team password store).
# .env is gitignored; never commit real credentials.

E2E_USER_EMAIL=test@photato.eu
E2E_USER_PASSWORD=your-password-here

# Optional overrides:
# Target to run against. Default: https://photato.eu (the live legacy site).
# Phase 5 points this at the new Hetzner deployment (e.g. https://photato.eu after cutover, or a staging URL).
# BASE_URL=https://photato.eu

# Whether the legacy AWS/Mongo backend is dead (502). Default: true.
# Phase 5 flips this to false once the Go backend is live, which enables the
# upload/course/admin functional baselines that need a working backend.
# LEGACY_BACKEND_DEAD=true
