{
  "name": "@photato/frontend",
  "version": "8.0.0",
  "description": "The Photato website front end. Svelte 5 SPA, TypeScript (strict), vanilla CSS, built with Vite. Magic-link auth against the Go backend; Umami analytics.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "oxfmt . && prettier --write \"src/**/*.svelte\"",
    "format:check": "oxfmt --check . && prettier --check \"src/**/*.svelte\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdavid/photato.git"
  },
  "keywords": [
    "photato",
    "photo",
    "photography",
    "website",
    "potato"
  ],
  "author": "David Veszelovszki",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "oxfmt": "^0.46.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.1.3"
  }
}
